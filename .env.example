# =============================================================================
# Vectory Environment Configuration
# Copy to .env and edit: cp .env.example .env
# =============================================================================

# -- Postgres --
POSTGRES_USER=vectoruser
POSTGRES_PASSWORD=vectorpass
POSTGRES_DB=vectory
DATABASE_URL=postgresql://vectoruser:vectorpass@postgres:5432/vectory

# -- Redis --
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -- MinIO / S3 --
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=vectory-uploads
MINIO_SECURE=false

# -- Backend --
# Port the backend listens on. Change if 8000 is already in use.
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=info

# -- JWT (CHANGE THESE IN PRODUCTION!) --
JWT_SECRET=your-super-secret-jwt-key-change-me-min-32-characters
JWT_REFRESH_SECRET=your-refresh-secret-key-change-me-min-32-characters
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Embedding Provider API Keys --
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
COHERE_API_KEY=...

# -- Embedding Defaults --
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
DEFAULT_DIMENSION=1536
DEFAULT_DISTANCE_METRIC=cosine

# -- Frontend --
# BACKEND_URL: where the Next.js server proxies /api/* requests (Docker-internal).
# NEXT_PUBLIC_API_URL: browser-accessible backend URL (used at build time).
# Both should use the same port as BACKEND_PORT.
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# -- Rate Limiting & Uploads --
RATE_LIMIT_PER_MINUTE=100
MAX_UPLOAD_SIZE_MB=100

# -- Performance --
VECTOR_BATCH_SIZE=1000
MAX_WORKERS=4
POOL_SIZE=20
